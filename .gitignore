# Binaries for programs and plugins
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artefacts
*.out
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Environment file
.env

# Editor/IDE
.idea/
.vscode/

# AI
AGENTS.md
CONTEXT.md
docs/ai/
.agents/
.claude/
.codex/
.codex
.pi/
.pi-lens/

# Repo-local caches and tooling
.cache/

# Miscellaneous
